# Password for /slides (presentations index + decks). Server-only; not exposed to the client bundle.
# When unset, slides stay inaccessible until configured.
SLIDES_PASSWORD=

# Convex deployment URL (from Convex dashboard after running `npx convex dev`)
# Required for the frontend to connect to your Convex backend.
# Optional alias for server-only code (sitemap route); falls back to VITE_CONVEX_URL if unset.
CONVEX_URL=
VITE_CONVEX_URL=

# Public site URL (no trailing slash). Used for Open Graph image URLs. Defaults to https://ailabs.sv
VITE_SITE_URL=

# Clerk secret key (from Clerk Dashboard > API Keys)
# Required for server-side auth. No VITE_ prefix - stays server-only.
CLERK_SECRET_KEY=

# MCP (Cursor): conversational event upsert via scripts/mcp-events-server.ts
# Base URL of your Convex deployment HTTP endpoint (same host as VITE_CONVEX_URL, https://<name>.convex.site — no trailing slash).
CONVEX_HTTP_URL=
# Shared secret: set the same value in Convex dashboard as ADMIN_MCP_SECRET (Functions env).
ADMIN_MCP_SECRET=

# Cloudflare Turnstile — site key is public (Vite). Secret is server-only: set TURNSTILE_SECRET in Convex (Dashboard → Settings → Environment Variables, or `npx convex env set TURNSTILE_SECRET <value>`).
# The secret MUST pair with the site key. Mixing test site key + production secret (or vice versa) yields invalid-input-response from siteverify.
# Test pair (always passes): site key 1x00000000000000000000AA — secret 1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=
# Local reference only; production verification uses Convex env, not this file.
TURNSTILE_SECRET=

# Optional: Cloudflare R2 (S3-compatible) for presigned uploads via convex/r2.getPresignedPutUrl — set all or none.
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=https://<your-public-bucket-host>

# Apple Wallet founder pass — set in Convex Dashboard (Functions → Environment Variables), not Vite.
# PEM strings: paste full certificate/key including -----BEGIN … -----END … (multiline supported in dashboard).
# WWDR: Apple Worldwide Developer Relations intermediate (PEM). Signer: Pass Type ID certificate + private key.
# APPLE_PASS_WWDR_PEM=
# APPLE_PASS_SIGNER_CERT_PEM=
# APPLE_PASS_SIGNER_KEY_PEM=
# APPLE_PASS_SIGNER_KEY_PASSPHRASE=   # optional, if the .p12 key was encrypted
# APPLE_PASS_TYPE_ID=pass.com.your.bundle
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_PASS_ORGANIZATION_NAME=ailabs
# Founder passes (3 variants): `links` uses this URL for the QR; Walter/Daniela use WhatsApp.
# PASS_LINKS_QR_URL=https://ailabs.sv/links
# VITE_PASS_LINKS_QR_URL=https://ailabs.sv/links
# Country code for wa.me on the two WhatsApp passes (default 503 = El Salvador).
# PASS_WHATSAPP_CC=503
# VITE_PASS_WHATSAPP_CC=503
